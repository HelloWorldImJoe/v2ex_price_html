{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "v2ex-price-html",
  "main": "src/index.ts",
  "compatibility_date": "2025-10-08",
  "compatibility_flags": ["nodejs_compat"],
  "upload_source_maps": true,
  "observability": {
    "enabled": true
  },
  "browser": {
    "binding": "MYBROWSER"
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "SCREENSHOT_DO",
        "class_name": "ScreenshotDO"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["ScreenshotDO"]
    }
  ]
}
